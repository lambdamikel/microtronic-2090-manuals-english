          697
        ]
      ],
      "kind": "body"
    },
    {
      "bbox": [
        135,
        827,
        1197,
        945
      ],
      "text": "Kein Wunder, daß der Computer für die Aufgabe 9999 : 1 einige Sekunden benötigt. Trotzdem isteserstaunlich, in welcher Ge- schwindigkeit 9999 -1 -1 -1.... usw. gerechnet wird.",
      "lines": [
        [
          136,
          827,
          1194,
          863
        ],
        [
          135,
          868,
          1197,
          904
        ],
        [
          135,
