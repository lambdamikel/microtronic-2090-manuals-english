    },
    {
      "bbox": [
        1262,
        245,
        2324,
        326
      ],
      "text": "Der ROM-Speicher unseres Mikroprozessors ist für das Be- triebs-System (Monitor-Programm) zuständig.",
      "lines": [
        [
          1264,
          245,
          2324,
          284
        ],
        [
          1262,
          287,
          2056,
          326
        ]
      ],
      "kind": "body"
    },
    {
      "bbox": [
        1263,
        351,
        2324,
        433
      ],
      "text": "Außerdem ist ein RAM-Speicher für die Register-Inhalte inte- griert.",
      "lines": [
        [
          1263,
          351,
          2324,
          389
        ],
        [
          1264,
          398,
          1359,
          433
        ]
      ],
      "kind": "body"
    },
    {
      "bbox": [
        1264,
        457,
        2325,
        574
      ],
      "text": "Unsere eingegebenen Programme werden in einem separaten RAM-Speicher Baustein (auf der Computer-Platine) gespei- chert.",
      "lines": [
        [
          1264,
          457,
          2321,
          496
        ],
        [
          1265,
          498,
          2325,
          538
        ],
        [
