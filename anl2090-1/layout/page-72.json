    },
    {
      "bbox": [
        1251,
        337,
        2313,
        496
      ],
      "text": "Der Programm-Speicher wird nun durch die Batterie-Span- nung betriebsbereit gehalten, während alle übrigen Computer- Funktionen abgeschaltet sind. Es kann also mit Batteriebetrieb nicht weitergearbeitet werden.",
      "lines": [
        [
          1251,
          337,
          2313,
          373
        ],
        [
          1251,
          378,
          2312,
          414
        ],
        [
