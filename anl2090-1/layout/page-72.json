    },
    {
      "bbox": [
        1248,
        520,
        2310,
        719
      ],
      "text": "Vor dem Einstecken des Netzgeräts in die Steckdose ist erneut die RESET-Taste ca. 10 Sekunden lang zu drücken, dann (bei gedrückter RESET-Taste) das Netzgerät einstecken. Nach dem Einstecken die RESET-Taste noch ca. 10 Sekunden in Druckstellung halten.",
      "lines": [
        [
          1248,
          520,
          2310,
          555
        ],
        [
          1249,
          560,
          2309,
          596
        ],
        [
